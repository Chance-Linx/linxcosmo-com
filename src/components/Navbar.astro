---
---

<header class="bde-header" style="background-color: #3b82f6; position: sticky; top: 0; z-index: 1000;">
  <div style="max-width: 1200px; margin: 0 auto; padding: 0 20px; display: flex; align-items: center; justify-content: space-between; height: 70px;">
    
    <!-- Logo -->
    <h1 style="color: #ffffff; font-size: 33px; font-weight: 700; margin: 0; font-family: system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; letter-spacing: 1px;">
      LINXCOSMO
    </h1>
    
    <!-- Desktop Navigation -->
    <nav style="display: flex; align-items: center; gap: 24px;">
      <a href="#" style="color: #ffffff; font-size: 16px; font-weight: 400; text-decoration: none; opacity: 0.9;">Home</a>
      <a href="#" style="color: #ffffff; font-size: 16px; font-weight: 400; text-decoration: none; opacity: 0.9;">Services</a>
      <a href="https://linxcosmo.com/about/" style="color: #ffffff; font-size: 16px; font-weight: 400; text-decoration: none; opacity: 0.9;">About</a>
      <a href="#" style="color: #ffffff; font-size: 16px; font-weight: 400; text-decoration: none; opacity: 0.9;">Contact</a>
      
      <!-- Phone Button -->
      <a href="tel:+16128885122" style="display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; background-color: transparent; border: 1px solid rgba(255,255,255,0.4); color: #ffffff; font-size: 14px; font-weight: 500; text-decoration: none; border-radius: 4px;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        +1 612-888-5122
      </a>
      
      <!-- Mobile Menu Toggle -->
      <button id="mobile-toggle" style="display: none; background: none; border: none; color: #ffffff; cursor: pointer; padding: 8px;" aria-label="Toggle Menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 12h18M3 6h18M3 18h18"/>
        </svg>
      </button>
    </nav>
  </div>
  
  <!-- Mobile Menu -->
  <div id="mobile-menu" style="display: none; background-color: #2563eb; padding: 16px 20px;">
    <div style="display: flex; flex-direction: column; gap: 12px;">
      <a href="#" style="color: #ffffff; font-size: 16px; text-decoration: none;">Home</a>
      <a href="#" style="color: #ffffff; font-size: 16px; text-decoration: none;">Services</a>
      <a href="https://linxcosmo.com/about/" style="color: #ffffff; font-size: 16px; text-decoration: none;">About</a>
      <a href="#" style="color: #ffffff; font-size: 16px; text-decoration: none;">Contact</a>
      <a href="tel:+16128885122" style="color: #ffffff; font-size: 16px; text-decoration: none;">+1 612-888-5122</a>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
    });
  }
</script>
