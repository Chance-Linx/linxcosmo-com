---
---

<section id="contact" class="py-24 md:py-32 bg-brand-dark relative overflow-hidden">
  <!-- Decorative Elements -->
  <div class="absolute top-0 right-0 w-96 h-96 bg-brand-gold/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>
  <div class="absolute bottom-0 left-0 w-64 h-64 bg-brand-gold/5 rounded-full translate-y-1/2 -translate-x-1/2"></div>
  
  <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-24">
      <!-- Info -->
      <div class="reveal">
        <p class="text-brand-gold text-sm font-medium tracking-[0.25em] uppercase mb-4">Get in Touch</p>
        <h2 class="font-serif text-4xl md:text-5xl font-medium text-white leading-tight mb-8">
          Let's Start a<br/>
          <span class="italic text-brand-gold">Conversation</span>
        </h2>
        <p class="text-white/60 leading-relaxed mb-12 max-w-md">
          Whether you're interested in our products, partnerships, or simply want to learn more about LinxCosmo, we'd love to hear from you.
        </p>
        
        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 border border-brand-gold/30 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-brand-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="text-white font-medium mb-1">Email</p>
              <a href="mailto:hello@linxcosmo.com" class="text-white/60 hover:text-brand-gold transition-colors">hello@linxcosmo.com</a>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 border border-brand-gold/30 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-brand-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 11c0-1.657-1.343-3-3-3s-3 1.343-3 3c0 1.657 1.343 3 3 3s3-1.343 3-3zm0 0l6 6m-6-6l-6 6" />
              </svg>
            </div>
            <div>
              <p class="text-white font-medium mb-1">Location</p>
              <p class="text-white/60">Linxcosmo LLC<br/>55th Broadway Str. NY</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 border border-brand-gold/30 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-brand-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <p class="text-white font-medium mb-1">Phone</p>
              <a href="tel:+16128885122" class="text-white/60 hover:text-brand-gold transition-colors">+1 612-888-5122</a>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Form -->
      <div class="reveal reveal-delay-2">
        <form id="contact-form" class="space-y-6">
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-white/80 text-sm mb-2">Name</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                required
                class="w-full bg-transparent border border-white/20 px-4 py-3 text-white placeholder-white/30 focus:border-brand-gold focus:outline-none transition-colors"
                placeholder="Your name"
              />
            </div>
            <div>
              <label for="email" class="block text-white/80 text-sm mb-2">Email</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required
                class="w-full bg-transparent border border-white/20 px-4 py-3 text-white placeholder-white/30 focus:border-brand-gold focus:outline-none transition-colors"
                placeholder="your@email.com"
              />
            </div>
          </div>
          
          <div>
            <label for="subject" class="block text-white/80 text-sm mb-2">Subject</label>
            <input 
              type="text" 
              id="subject" 
              name="subject" 
              required
              class="w-full bg-transparent border border-white/20 px-4 py-3 text-white placeholder-white/30 focus:border-brand-gold focus:outline-none transition-colors"
              placeholder="How can we help?"
            />
          </div>
          
          <div>
            <label for="message" class="block text-white/80 text-sm mb-2">Message</label>
            <textarea 
              id="message" 
              name="message" 
              rows="5" 
              required
              class="w-full bg-transparent border border-white/20 px-4 py-3 text-white placeholder-white/30 focus:border-brand-gold focus:outline-none transition-colors resize-none"
              placeholder="Tell us more about your inquiry..."
            ></textarea>
          </div>
          
          <button 
            type="submit"
            class="w-full md:w-auto px-10 py-4 bg-brand-gold text-brand-black font-medium text-sm tracking-wide uppercase hover:bg-brand-gold-light transition-colors duration-300"
          >
            Send Message
          </button>
        </form>
        
        <!-- Success Message -->
        <div id="form-success" class="hidden mt-6 p-6 border border-brand-gold/30">
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-brand-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <p class="text-white">Thank you for reaching out! We'll get back to you soon.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form');
  const successMsg = document.getElementById('form-success');
  
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(form);
    const data = Object.fromEntries(formData);
    
    // Simulate form submission (replace with actual API endpoint)
    try {
      // Here you would send to your API route, e.g.:
      // const response = await fetch('/api/contact', {
      //   method: 'POST',
      //   headers: { 'Content-Type': 'application/json' },
      //   body: JSON.stringify(data)
      // });
      
      // For now, just show success
      form.classList.add('hidden');
      successMsg.classList.remove('hidden');
    } catch (error) {
      console.error('Form submission error:', error);
    }
  });
</script>
