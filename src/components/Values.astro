---
const values = [
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>`,
    title: "Innovation",
    description: "Pushing boundaries with creative solutions that redefine everyday products."
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>`,
    title: "Quality",
    description: "Uncompromising standards in materials, craftsmanship, and design execution."
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    title: "Sustainability",
    description: "Committed to eco-conscious practices that respect our planet and future generations."
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>`,
    title: "Community",
    description: "Building connections and fostering a global family of inspired individuals."
  }
];
---

<section id="values" class="py-24 md:py-32 bg-brand-cream">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Header -->
    <div class="reveal text-center mb-20">
      <p class="text-brand-gold text-sm font-medium tracking-[0.25em] uppercase mb-4">What We Stand For</p>
      <h2 class="font-serif text-4xl md:text-5xl font-medium text-brand-dark leading-tight">
        Our Core Values
      </h2>
    </div>
    
    <!-- Values Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      {values.map((value, index) => (
        <div class={`reveal reveal-delay-${index + 1} group p-8 border border-brand-dark/10 hover:border-brand-gold/50 transition-colors duration-500`}>
          <div class="text-brand-gold mb-6 transform group-hover:scale-110 transition-transform duration-300">
            <Fragment set:html={value.icon} />
          </div>
          <h3 class="font-serif text-xl font-medium text-brand-dark mb-4">{value.title}</h3>
          <p class="text-brand-gray text-sm leading-relaxed">{value.description}</p>
        </div>
      ))}
    </div>
    
    <!-- Quote Section -->
    <div class="reveal mt-24 text-center max-w-4xl mx-auto">
      <div class="w-12 h-px bg-brand-gold mx-auto mb-8"></div>
      <blockquote class="font-serif text-2xl md:text-3xl text-brand-dark italic leading-relaxed mb-6">
        "We believe in the power of creativity to make a positive impact on the world and are committed to using our platform to foster a more connected and vibrant global society."
      </blockquote>
      <p class="text-brand-gray text-sm tracking-wide uppercase">— The LinxCosmo Team</p>
    </div>
  </div>
</section>
