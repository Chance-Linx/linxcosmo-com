---
const categories = [
  {
    title: "Home & Living",
    description: "Elegant essentials that bring warmth and sophistication to every room.",
    image: "https://images.unsplash.com/photo-1616486338812-3dadae4b4ace?q=80&w=800&auto=format&fit=crop"
  },
  {
    title: "Garden & Outdoor",
    description: "Create your perfect outdoor sanctuary with our curated garden collection.",
    image: "https://images.unsplash.com/photo-1558904541-efa843a96f01?q=80&w=800&auto=format&fit=crop"
  },
  {
    title: "Sports & Fitness",
    description: "Premium gear designed to elevate your performance and active lifestyle.",
    image: "https://images.unsplash.com/photo-1517836357463-d25dfeac3438?q=80&w=800&auto=format&fit=crop"
  },
  {
    title: "Pet Care",
    description: "Thoughtfully designed products that keep your companions happy and healthy.",
    image: "https://images.unsplash.com/photo-1450778869180-41d0601e046e?q=80&w=800&auto=format&fit=crop"
  },
  {
    title: "Beauty & Wellness",
    description: "Indulge in self-care with our refined beauty and wellness essentials.",
    image: "https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?q=80&w=800&auto=format&fit=crop"
  },
  {
    title: "Personal Protection",
    description: "Innovative safety solutions that blend seamlessly into your daily routine.",
    image: "https://images.unsplash.com/photo-1583947215259-38e31be8751f?q=80&w=800&auto=format&fit=crop"
  }
];
---

<section id="categories" class="py-24 md:py-32 bg-brand-dark">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Header -->
    <div class="reveal text-center mb-20">
      <p class="text-brand-gold text-sm font-medium tracking-[0.25em] uppercase mb-4">Curated for You</p>
      <h2 class="font-serif text-4xl md:text-5xl font-medium text-white leading-tight">
        Our Collections
      </h2>
      <p class="text-white/50 mt-6 max-w-xl mx-auto leading-relaxed">
        Six distinct categories, each crafted with precision and passion to enhance every aspect of your life.
      </p>
    </div>
    
    <!-- Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {categories.map((cat, index) => (
        <div class={`reveal reveal-delay-${(index % 3) + 1} group cursor-pointer`}>
          <div class="img-zoom relative aspect-[4/5] overflow-hidden bg-brand-black">
            <img 
              src={cat.image} 
              alt={cat.title}
              class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity duration-500"
            />
            <div class="absolute inset-0 bg-brand-black/30 group-hover:bg-brand-black/10 transition-colors duration-500"></div>
            
            <!-- Content Overlay -->
            <div class="absolute bottom-0 left-0 right-0 p-8">
              <div class="transform translate-y-2 group-hover:translate-y-0 transition-transform duration-500">
                <p class="text-brand-gold text-xs font-medium tracking-[0.2em] uppercase mb-2">0{index + 1}</p>
                <h3 class="font-serif text-2xl text-white font-medium mb-3">{cat.title}</h3>
                <p class="text-white/60 text-sm leading-relaxed opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-100">
                  {cat.description}
                </p>
              </div>
            </div>
            
            <!-- Arrow -->
            <div class="absolute top-6 right-6 w-10 h-10 border border-white/30 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 17L17 7M17 7H7M17 7v10" />
              </svg>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
