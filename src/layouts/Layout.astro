---
export interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "LINXCOSMO LLC", 
  description = "A dynamic and innovative company dedicated to enhancing everyday life through our unique and creative lifestyle products." 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en-US">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#3b82f6" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>{title}</title>
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://linxcosmo.com" />
    
    <!-- Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "LinxCosmo",
        "url": "https://linxcosmo.com",
        "description": "A dynamic and innovative company dedicated to enhancing everyday life through our unique and creative lifestyle products.",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "55th Broadway Str.",
          "addressLocality": "NY",
          "addressCountry": "US"
        }
      }
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
